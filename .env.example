# Open Brain Environment Variables
# Copy to .env and fill in your values

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openbrain
DB_USER=openbrain
DB_PASSWORD=changeme

# Embedder Provider: "ollama" (local, free) or "openrouter" (cloud, paid)
EMBEDDER_PROVIDER=ollama
EMBEDDING_DIMENSIONS=768

# Ollama (when EMBEDDER_PROVIDER=ollama)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.2

# OpenRouter (when EMBEDDER_PROVIDER=openrouter)
# OPENROUTER_API_KEY=sk-or-your-key-here
# OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
# OPENROUTER_LLM_MODEL=openai/gpt-4o-mini

# MCP Server Authentication
# Generate with: openssl rand -hex 32
MCP_ACCESS_KEY=your-64-char-hex-key-here

# Server Ports
API_PORT=8000
MCP_PORT=8080

# Logging
LOG_LEVEL=info
