{
  "name": "openbrain",
  "version": "1.0.0",
  "description": "Personal semantic memory system with MCP interface",
  "author": "Scott Nichols",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/srnichols/OpenBrain.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "semantic-search",
    "pgvector",
    "ollama",
    "memory",
    "knowledge-base",
    "ai-tools"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:stdio": "node dist/stdio.js",
    "dev": "tsx watch src/index.ts",
    "dev:stdio": "tsx src/stdio.ts",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "import:markdown": "node dist/import/markdown-cli.js",
    "import:parity": "node dist/import/parity-cli.js",
    "ryel:semantic-json": "python3 scripts/ryel_semantic_json.py"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.25",
    "jose": "^6.2.3",
    "onnxruntime-node": "^1.26.0",
    "pg": "^8.13.1",
    "pgvector": "^0.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/pg": "^8.11.11",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  }
}
